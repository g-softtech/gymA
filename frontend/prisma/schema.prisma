datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

enum NotificationType {
  PAYMENT
  SUBSCRIPTION_EXPIRY
  ATTENDANCE
  BOOKING
  MESSAGE
  COMMUNITY
  GENERAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

enum SessionType {
  PHYSICAL
  ONLINE
}

enum DietGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  GENERAL_HEALTH
}

enum BadgeType {
  FIRST_CHECKIN
  STREAK_7
  STREAK_30
  FIRST_BOOKING
  FIRST_WORKOUT
  CHALLENGE_COMPLETE
  COMMUNITY_STAR
  WEIGHT_GOAL
}

enum ChallengeType {
  ATTENDANCE
  WORKOUT
  WEIGHT_LOSS
  STEPS
  CUSTOM
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Tenant {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  // ── SaaS billing ──────────────────────────────────────────────────────────
  plan            TenantPlan       @default(FREE)
  trialEndsAt     DateTime?
  isActive        Boolean          @default(true)
  // ── Relations ────────────────────────────────────────────────────────────
  users           User[]
  membershipPlans MembershipPlan[]
  notifications   Notification[]
  messages        Message[]
  settings        TenantSettings?
  blogPosts       BlogPost[]
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  role             Role             @default(MEMBER)
  tenantId         String?
  tenant           Tenant?          @relation(fields: [tenantId], references: [id])
  accounts         Account[]
  sessions         Session[]
  memberProfile    MemberProfile?
  trainerProfile   TrainerProfile?
  notifications    Notification[]
  sentMessages     Message[]        @relation("SentMessages")
  posts            Post[]           @relation("UserPosts")
  postLikes        PostLike[]       @relation("UserLikes")
  comments         Comment[]        @relation("UserComments")
  challengeEntries ChallengeEntry[] @relation("UserChallenges")
  badges           Badge[]          @relation("UserBadges")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MemberProfile {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg        Float?
  heightCm        Float?
  fitnessGoals    String[]
  subscriptions   Subscription[]
  workouts        WorkoutPlan[]
  attendance      Attendance[]
  bookings        Booking[]
  progressRecords ProgressRecord[]
  mealPlans       MealPlan[]
  foodLogs        FoodLog[]
}

model TrainerProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties  String[]
  availability Json
  bio          String?
  hourlyRate   Float?
  bookings     Booking[]
  workoutPlans WorkoutPlan[]
}

model MembershipPlan {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  price         Float
  durationDays  Int
  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  memberId         String
  member           MemberProfile      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId           String
  plan             MembershipPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId         String
  startDate        DateTime           @default(now())
  endDate          DateTime
  status           SubscriptionStatus @default(ACTIVE)
  paymentGatewayId String?

  @@index([tenantId, status])
}

model WorkoutPlan {
  id            String          @id @default(cuid())
  memberId      String
  member        MemberProfile   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainerId     String?
  trainer       TrainerProfile? @relation(fields: [trainerId], references: [id])
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId      String
  title         String          @default("My Workout Plan")
  routines      Json
  isAiGenerated Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId, createdAt])
}

model Booking {
  id           String         @id @default(cuid())
  trainerId    String
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  memberId     String
  member       MemberProfile  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenantId     String
  date         DateTime
  durationMins Int            @default(60)
  sessionType  SessionType    @default(PHYSICAL)
  status       BookingStatus  @default(PENDING)
  notes        String?
  meetingLink  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([trainerId, date])
  @@index([memberId])
  @@index([tenantId, status])
}

model Attendance {
  id          String        @id @default(cuid())
  memberId    String
  member      MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenantId    String
  checkedInAt DateTime      @default(now())
  note        String?

  @@index([tenantId, checkedInAt])
  @@index([memberId])
}

model ProgressRecord {
  id         String        @id @default(cuid())
  memberId   String
  member     MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId   String
  recordedBy String
  weightKg   Float?
  bodyFatPct Float?
  muscleMass Float?
  chestCm    Float?
  waistCm    Float?
  hipsCm     Float?
  notes      String?
  recordedAt DateTime      @default(now())

  @@index([memberId, recordedAt])
  @@index([tenantId, recordedAt])
}

model MealPlan {
  id            String        @id @default(cuid())
  memberId      String
  member        MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId      String
  title         String
  goal          DietGoal      @default(GENERAL_HEALTH)
  totalCalories Int
  protein       Float
  carbs         Float
  fats          Float
  meals         Json
  isAiGenerated Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([memberId])
  @@index([tenantId, createdAt])
}

model FoodLog {
  id        String        @id @default(cuid())
  memberId  String
  member    MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId  String
  date      DateTime      @default(now())
  mealType  String
  foodName  String
  calories  Int
  protein   Float
  carbs     Float
  fats      Float
  quantity  Float         @default(1)
  unit      String        @default("serving")
  createdAt DateTime      @default(now())

  @@index([memberId, date])
  @@index([tenantId, date])
}

model Post {
  id        String     @id @default(cuid())
  tenantId  String
  authorId  String
  author    User       @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  imageUrl  String?
  likes     PostLike[]
  comments  Comment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([tenantId, createdAt])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model Challenge {
  id          String           @id @default(cuid())
  tenantId    String
  title       String
  description String
  type        ChallengeType    @default(CUSTOM)
  goal        Int
  unit        String
  startDate   DateTime
  endDate     DateTime
  createdBy   String
  entries     ChallengeEntry[]
  createdAt   DateTime         @default(now())

  @@index([tenantId])
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("UserChallenges", fields: [userId], references: [id], onDelete: Cascade)
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  joinedAt    DateTime  @default(now())

  @@unique([challengeId, userId])
  @@index([challengeId, progress])
}

model Badge {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)
  type      BadgeType
  awardedAt DateTime  @default(now())

  @@unique([userId, type])
  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([tenantId, read])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2: New Models
// ─────────────────────────────────────────────────────────────────────────────

model TenantSettings {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── Branding ──────────────────────────────────────────────────────────────
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String? // e.g. "#6366F1"
  secondaryColor  String?
  accentColor     String?
  fontFamily      String? // e.g. "Inter"
  darkMode        Boolean @default(false)

  // ── Domain ────────────────────────────────────────────────────────────────
  customDomain    String? @unique
  subdomain       String? @unique
  domainVerified  Boolean @default(false)

  // ── Business Info ─────────────────────────────────────────────────────────
  tagline         String?
  description     String? @db.Text
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  country         String? @default("Nigeria")
  mapEmbedUrl     String?

  // ── Social Links ──────────────────────────────────────────────────────────
  instagramUrl    String?
  facebookUrl     String?
  twitterUrl      String?
  tiktokUrl       String?
  whatsappNumber  String?
  youtubeUrl      String?

  // ── Marketing CMS (JSON blobs, one per section) ───────────────────────────
  heroData        Json?  // { headline, subheadline, ctaText, ctaUrl, bgImageUrl, overlayOpacity }
  aboutData       Json?  // { story, mission, vision, teamImageUrl, foundedYear, highlights[] }
  servicesData    Json?  // [{ icon, title, description, imageUrl }]
  galleryData     Json?  // [{ imageUrl, caption, category }]
  testimonialData Json?  // [{ name, role, quote, avatarUrl, rating }]
  contactData     Json?  // { formEnabled, successMessage }
  featuresData    Json?  // [{ icon, title, description }]
  statsData       Json?  // [{ value, label }]
  openingHours    Json?  // { monday: { open, close }, tuesday: ... }

  // ── SEO ───────────────────────────────────────────────────────────────────
  metaTitle         String?
  metaDescription   String?
  ogImageUrl        String?
  googleAnalyticsId String?

  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId    String
  title       String
  slug        String
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, published, publishedAt])
}
