generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  plan             TenantPlan        @default(FREE)
  trialEndsAt      DateTime?
  billingEndsAt    DateTime?
  planStartedAt    DateTime?
  isActive         Boolean           @default(true)
  status           TenantStatus      @default(PENDING)
  billingStatus    String            @default("ACTIVE")
  attendances      Attendance[]
  attendanceEvents AttendanceEvent[]
  blogPosts        BlogPost[]
  classSessions    ClassSession[]
  entitlementLogs  EntitlementLog[]
  membershipPlans  MembershipPlan[]
  messages         Message[]
  notifications    Notification[]
  receipts         Receipt[]
  saasInvoices     SaaSInvoice[]
  subscriptions    Subscription[]
  settings         TenantSettings?
  transactions     Transaction[]
  users            User[]

  @@index([billingStatus])
  @@index([billingEndsAt])
  @@index([trialEndsAt])
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role             @default(MEMBER)
  tenantId         String?
  accounts         Account[]
  badges           Badge[]          @relation("UserBadges")
  challengeEntries ChallengeEntry[] @relation("UserChallenges")
  comments         Comment[]        @relation("UserComments")
  entitlementLogs  EntitlementLog[]
  memberProfile    MemberProfile?
  sentMessages     Message[]        @relation("SentMessages")
  notifications    Notification[]
  posts            Post[]           @relation("UserPosts")
  postLikes        PostLike[]       @relation("UserLikes")
  sessions         Session[]
  trainerProfile   TrainerProfile?
  tenant           Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MemberProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  weightKg         Float?
  heightCm         Float?
  fitnessGoals     String[]
  lastQrNonce      String?
  qrNonceExpiresAt DateTime?
  attendances      Attendance[]
  bookings         Booking[]
  foodLogs         FoodLog[]
  mealPlans        MealPlan[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressRecords  ProgressRecord[]
  receipts         Receipt[]
  subscriptions    Subscription[]
  transactions     Transaction[]
  workouts         WorkoutPlan[]
}

model TrainerProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  specialties       String[]
  availability      Json
  bio               String?
  hourlyRate        Decimal?       @db.Decimal(10, 2)
  showOnWebsite     Boolean        @default(false)
  publicPhotoUrl    String?
  title             String?
  yearsOfExperience Int?
  bookings          Booking[]
  classSessions     ClassSession[]
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutPlans      WorkoutPlan[]
}

model MembershipPlan {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  price           Decimal          @db.Decimal(10, 2)
  durationDays    Int
  featured        Boolean          @default(false)
  description     String?
  features        String[]
  currency        Currency         @default(NGN)
  isActive        Boolean          @default(true)
  entitlements    Json             @default("{}")
  entitlementLogs EntitlementLog[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]

  @@index([tenantId])
}

model Subscription {
  id               String           @id @default(cuid())
  memberId         String
  planId           String
  tenantId         String
  startDate        DateTime         @default(now())
  endDate          DateTime
  paymentGatewayId String?          @unique
  status           MembershipStatus @default(PENDING_PAYMENT)
  member           MemberProfile    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan             MembershipPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model WorkoutPlan {
  id            String          @id @default(cuid())
  memberId      String
  trainerId     String?
  tenantId      String
  title         String          @default("My Workout Plan")
  routines      Json
  isAiGenerated Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  member        MemberProfile   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer       TrainerProfile? @relation(fields: [trainerId], references: [id])

  @@index([tenantId, createdAt])
}

model ClassSession {
  id           String          @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  instructorId String?
  startTime    DateTime
  durationMins Int             @default(60)
  capacity     Int
  imageUrl     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  price        Decimal?        @db.Decimal(10, 2)
  bookings     Booking[]
  instructor   TrainerProfile? @relation(fields: [instructorId], references: [id])
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startTime])
}

model Booking {
  id               String          @id @default(cuid())
  trainerId        String?
  memberId         String
  tenantId         String
  date             DateTime
  durationMins     Int             @default(60)
  sessionType      SessionType     @default(PHYSICAL)
  status           BookingStatus   @default(PENDING)
  notes            String?
  meetingLink      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  classSessionId   String?
  paymentAmount    Decimal?        @db.Decimal(10, 2)
  paymentExpiresAt DateTime?
  paymentRequired  Boolean         @default(false)
  paymentStatus    PaymentStatus   @default(PENDING)
  attendances      Attendance[]
  classSession     ClassSession?   @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  member           MemberProfile   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer          TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId, date])
  @@index([classSessionId])
  @@index([memberId])
  @@index([tenantId, status])
}

model Attendance {
  id           String            @id @default(cuid())
  memberId     String
  tenantId     String
  bookingId    String?
  checkInTime  DateTime          @default(now())
  checkOutTime DateTime?
  method       CheckInMethod
  status       AttendanceStatus  @default(PRESENT)
  type         AttendanceType
  booking      Booking?          @relation(fields: [bookingId], references: [id])
  member       MemberProfile     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events       AttendanceEvent[]

  @@unique([bookingId, memberId])
  @@index([tenantId, checkInTime])
}

model AttendanceEvent {
  id           String      @id @default(cuid())
  attendanceId String?
  tenantId     String
  memberId     String
  eventType    String
  overrideType String?
  timestamp    DateTime    @default(now())
  notes        String?
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ProgressRecord {
  id         String        @id @default(cuid())
  memberId   String
  tenantId   String
  recordedBy String
  weightKg   Float?
  bodyFatPct Float?
  muscleMass Float?
  chestCm    Float?
  waistCm    Float?
  hipsCm     Float?
  notes      String?
  recordedAt DateTime      @default(now())
  member     MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, recordedAt])
  @@index([tenantId, recordedAt])
}

model MealPlan {
  id            String        @id @default(cuid())
  memberId      String
  tenantId      String
  title         String
  goal          DietGoal      @default(GENERAL_HEALTH)
  totalCalories Int
  protein       Float
  carbs         Float
  fats          Float
  meals         Json
  isAiGenerated Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  member        MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId, createdAt])
}

model FoodLog {
  id        String        @id @default(cuid())
  memberId  String
  tenantId  String
  date      DateTime      @default(now())
  mealType  String
  foodName  String
  calories  Int
  protein   Float
  carbs     Float
  fats      Float
  quantity  Float         @default(1)
  unit      String        @default("serving")
  createdAt DateTime      @default(now())
  member    MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, date])
  @@index([tenantId, date])
}

model Post {
  id        String     @id @default(cuid())
  tenantId  String
  authorId  String
  content   String
  imageUrl  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comments  Comment[]
  author    User       @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]

  @@index([tenantId, createdAt])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  author    User     @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Challenge {
  id          String           @id @default(cuid())
  tenantId    String
  title       String
  description String
  type        ChallengeType    @default(CUSTOM)
  goal        Int
  unit        String
  startDate   DateTime
  endDate     DateTime
  createdBy   String
  createdAt   DateTime         @default(now())
  entries     ChallengeEntry[]

  @@index([tenantId])
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation("UserChallenges", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId, progress])
}

model Badge {
  id        String    @id @default(cuid())
  userId    String
  type      BadgeType
  awardedAt DateTime  @default(now())
  user      User      @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  tenantId   String
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String?
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, read])
  @@index([userId])
}

model TenantSettings {
  id                       String    @id @default(cuid())
  tenantId                 String    @unique
  logoUrl                  String?
  faviconUrl               String?
  primaryColor             String?
  secondaryColor           String?
  accentColor              String?
  fontFamily               String?
  darkMode                 Boolean   @default(false)
  brandName                String?
  whiteLabelEnabled        Boolean   @default(false)
  customDomain             String?   @unique
  subdomain                String?   @unique
  domainVerified           Boolean   @default(false)
  verificationToken        String?
  dnsVerifiedAt            DateTime?
  subscriptionPlan         String    @default("FREE")
  subscriptionStatus       String    @default("inactive")
  currentPeriodEnd         DateTime?
  tagline                  String?
  description              String?
  phone                    String?
  email                    String?
  address                  String?
  city                     String?
  state                    String?
  country                  String?   @default("Nigeria")
  mapEmbedUrl              String?
  instagramUrl             String?
  facebookUrl              String?
  twitterUrl               String?
  tiktokUrl                String?
  whatsappNumber           String?
  youtubeUrl               String?
  heroData                 Json?
  aboutData                Json?
  servicesData             Json?
  galleryData              Json?
  testimonialData          Json?
  contactData              Json?
  featuresData             Json?
  statsData                Json?
  openingHours             Json?
  metaTitle                String?
  metaDescription          String?
  ogImageUrl               String?
  googleAnalyticsId        String?
  updatedAt                DateTime  @updatedAt
  paystackCustomerCode     String?   @unique
  paystackEmailToken       String?
  paystackSubscriptionCode String?   @unique
  homepageLayout           Json?
  defaultCurrency          Currency  @default(NGN)
  tenant                   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String    @id @default(cuid())
  tenantId    String
  authorId    String
  title       String
  slug        String
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, published, publishedAt])
}

model AiLog {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  feature      AiFeature
  model        String    @default("gemini-2.0-flash")
  inputTokens  Int?
  outputTokens Int?
  success      Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, feature])
}

model ActionRegistry {
  id         String          @id @default(cuid())
  tenantId   String
  actionType String
  targetId   String
  context    String
  status     String          @default("PENDING")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  executedAt DateTime?
  feedback   ActionFeedback?
}

model ActionFeedback {
  id           String         @id @default(cuid())
  actionId     String         @unique
  beforeMetric Float
  afterMetric  Float?
  delta        Float?
  success      Boolean        @default(false)
  measuredAt   DateTime?
  action       ActionRegistry @relation(fields: [actionId], references: [id], onDelete: Cascade)
}

model SaaSInvoice {
  id        String   @id @default(cuid())
  tenantId  String
  amount    Decimal  @db.Decimal(10, 2)
  reference String   @unique
  status    String   @default("pending")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model BillingEvent {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String   @unique
  eventType String
  payload   Json
  createdAt DateTime @default(now())
}

model Transaction {
  id             String        @id @default(cuid())
  tenantId       String
  memberId       String
  itemName       String
  itemType       PaymentType
  amount         Decimal       @db.Decimal(10, 2)
  currency       Currency
  status         PaymentStatus @default(PENDING)
  reference      String        @unique
  metadata       Json?
  refundedAmount Decimal?      @db.Decimal(10, 2)
  refundReason   String?
  refundedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  receipt        Receipt?
  member         MemberProfile @relation(fields: [memberId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([memberId])
}

model PaymentEvent {
  id          String    @id @default(cuid())
  eventKey    String    @unique
  reference   String?
  eventType   String
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())
}

model EntitlementLog {
  id        String          @id @default(cuid())
  tenantId  String
  userId    String
  planId    String?
  feature   String
  allowed   Boolean
  reason    String?
  quantity  Int             @default(1)
  metadata  Json?
  createdAt DateTime        @default(now())
  plan      MembershipPlan? @relation(fields: [planId], references: [id])
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, planId])
  @@index([tenantId, feature, allowed])
  @@index([createdAt])
}

model ReceiptSequence {
  id        String @id @default(cuid())
  tenantId  String
  yearMonth String
  lastValue Int    @default(0)

  @@unique([tenantId, yearMonth])
}

model Receipt {
  id            String        @id @default(cuid())
  transactionId String        @unique
  receiptNumber String        @unique
  tenantId      String
  memberId      String
  sentAt        DateTime?
  status        String        @default("PENDING")
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  member        MemberProfile @relation(fields: [memberId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AdminNotificationLog {
  id             String                  @id @default(cuid())
  idempotencyKey String                  @unique
  type           AdminNotificationType
  status         AdminNotificationStatus @default(QUEUED)
  recipients     String
  payload        Json
  error          String?
  tenantId       String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([status])
  @@index([tenantId])
}

model CronLock {
  id        String   @id
  lockedAt  DateTime
  expiresAt DateTime
}

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  MEMBER
}

enum Currency {
  NGN
  USD
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
  PENDING_PAYMENT
  REPLACED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  MEMBERSHIP
  CLASS_BOOKING
  TRAINER_SESSION
  JOINING_FEE
}

enum NotificationType {
  PAYMENT
  SUBSCRIPTION_EXPIRY
  ATTENDANCE
  BOOKING
  MESSAGE
  COMMUNITY
  GENERAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  APPLE
}

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SessionType {
  PHYSICAL
  ONLINE
}

enum DietGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  GENERAL_HEALTH
}

enum BadgeType {
  FIRST_CHECKIN
  STREAK_7
  STREAK_30
  FIRST_BOOKING
  FIRST_WORKOUT
  CHALLENGE_COMPLETE
  COMMUNITY_STAR
  WEIGHT_GOAL
}

enum ChallengeType {
  ATTENDANCE
  WORKOUT
  WEIGHT_LOSS
  STEPS
  CUSTOM
}

enum TenantPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum CheckInMethod {
  QR
  MANUAL
  PIN
}

enum AttendanceStatus {
  PRESENT
  LATE
  NO_SHOW
}

enum AttendanceType {
  GENERAL
  CLASS
  TRAINER
  GUEST
}

enum AiFeature {
  CHAT
  WORKOUT
  NUTRITION
  PROGRESS
}

enum AdminNotificationType {
  NEW_TENANT_SIGNUP
}

enum AdminNotificationStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}
