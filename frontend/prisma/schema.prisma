datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  MEMBER
}

enum Currency {
  NGN
  USD
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
  PENDING_PAYMENT
  REPLACED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  MEMBERSHIP
  CLASS_BOOKING
  TRAINER_SESSION
  JOINING_FEE
}

enum NotificationType {
  PAYMENT
  SUBSCRIPTION_EXPIRY
  ATTENDANCE
  BOOKING
  MESSAGE
  COMMUNITY
  GENERAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  APPLE
}

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SessionType {
  PHYSICAL
  ONLINE
}

enum DietGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  GENERAL_HEALTH
}

enum BadgeType {
  FIRST_CHECKIN
  STREAK_7
  STREAK_30
  FIRST_BOOKING
  FIRST_WORKOUT
  CHALLENGE_COMPLETE
  COMMUNITY_STAR
  WEIGHT_GOAL
}

enum ChallengeType {
  ATTENDANCE
  WORKOUT
  WEIGHT_LOSS
  STEPS
  CUSTOM
}

enum TenantPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

model Tenant {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  // ── SaaS billing ──────────────────────────────────────────────────────────
  plan             TenantPlan        @default(FREE)
  trialEndsAt      DateTime?
  billingEndsAt    DateTime?
  planStartedAt    DateTime?
  isActive         Boolean           @default(true)
  status           TenantStatus      @default(PENDING)
  // ── Relations ────────────────────────────────────────────────────────────
  users            User[]
  membershipPlans  MembershipPlan[]
  notifications    Notification[]
  messages         Message[]
  settings         TenantSettings?
  blogPosts        BlogPost[]
  saasInvoices     SaaSInvoice[]
  classSessions    ClassSession[]
  transactions     Transaction[]
  attendances      Attendance[]
  entitlementLogs  EntitlementLog[]
  attendanceEvents AttendanceEvent[]
  receipts         Receipt[]
  subscriptions    Subscription[]
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  password         String? // bcrypt hash — null for OAuth users
  role             Role             @default(MEMBER)
  tenantId         String?
  tenant           Tenant?          @relation(fields: [tenantId], references: [id])
  accounts         Account[]
  sessions         Session[]
  memberProfile    MemberProfile?
  trainerProfile   TrainerProfile?
  notifications    Notification[]
  sentMessages     Message[]        @relation("SentMessages")
  posts            Post[]           @relation("UserPosts")
  postLikes        PostLike[]       @relation("UserLikes")
  comments         Comment[]        @relation("UserComments")
  challengeEntries ChallengeEntry[] @relation("UserChallenges")
  badges           Badge[]          @relation("UserBadges")
  entitlementLogs  EntitlementLog[]

  @@index([tenantId, role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MemberProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg         Float?
  heightCm         Float?
  fitnessGoals     String[]
  lastQrNonce      String?
  qrNonceExpiresAt DateTime?

  subscriptions   Subscription[]
  workouts        WorkoutPlan[]
  attendances     Attendance[]
  bookings        Booking[]
  progressRecords ProgressRecord[]
  mealPlans       MealPlan[]
  foodLogs        FoodLog[]
  transactions    Transaction[]
  receipts        Receipt[]
}

model TrainerProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties       String[]
  availability      Json
  bio               String?
  hourlyRate        Decimal?       @db.Decimal(10, 2)
  // ── Phase 6/13: Public website visibility ───────────────────────────────────
  showOnWebsite     Boolean        @default(false)
  publicPhotoUrl    String?
  title             String? // e.g. Head Coach, Yoga Instructor
  yearsOfExperience Int?
  bookings          Booking[]
  workoutPlans      WorkoutPlan[]
  classSessions     ClassSession[]
}

model MembershipPlan {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  price           Decimal          @db.Decimal(10, 2)
  currency        Currency         @default(NGN)
  isActive        Boolean          @default(true)
  durationDays    Int
  // ── Phase 6: Public plans page enhancements ───────────────────────────────
  featured        Boolean          @default(false)
  description     String?
  features        String[]
  entitlements    Json             @default("{}")
  subscriptions   Subscription[]
  entitlementLogs EntitlementLog[]

  @@index([tenantId])
}

model Subscription {
  id               String           @id @default(cuid())
  memberId         String
  member           MemberProfile    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId           String
  plan             MembershipPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startDate        DateTime         @default(now())
  endDate          DateTime
  status           MembershipStatus @default(PENDING_PAYMENT)
  paymentGatewayId String?          @unique

  @@index([tenantId, status])
}

model WorkoutPlan {
  id            String          @id @default(cuid())
  memberId      String
  member        MemberProfile   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainerId     String?
  trainer       TrainerProfile? @relation(fields: [trainerId], references: [id])
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId      String
  title         String          @default("My Workout Plan")
  routines      Json
  isAiGenerated Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId, createdAt])
}

model ClassSession {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  instructorId String?
  instructor   TrainerProfile? @relation(fields: [instructorId], references: [id])
  startTime    DateTime
  durationMins Int             @default(60)
  capacity     Int
  price        Decimal?        @db.Decimal(10, 2)
  imageUrl     String?
  bookings     Booking[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId, startTime])
}

model Booking {
  id       String        @id @default(cuid())
  tenantId String
  memberId String
  member   MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // -- 1-on-1 Booking Fields --
  trainerId String?
  trainer   TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  // -- Group Class Booking Fields --
  classSessionId String?
  classSession   ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  // -- Shared Context --
  date         DateTime
  durationMins Int           @default(60)
  sessionType  SessionType   @default(PHYSICAL)
  status       BookingStatus @default(PENDING)
  notes        String?
  meetingLink  String?

  // -- Phase 15 Payments --
  paymentRequired  Boolean       @default(false)
  paymentStatus    PaymentStatus @default(PENDING)
  paymentAmount    Decimal?      @db.Decimal(10, 2)
  paymentExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances Attendance[]

  @@index([trainerId, date])
  @@index([classSessionId])
  @@index([memberId])
  @@index([tenantId, status])
}

// ==========================================
// Phase 16: Attendance & Check-In
// ==========================================

enum CheckInMethod {
  QR
  MANUAL
  PIN
}

enum AttendanceStatus {
  PRESENT
  LATE
  NO_SHOW
}

enum AttendanceType {
  GENERAL
  CLASS
  TRAINER
  GUEST
}

model Attendance {
  id        String  @id @default(cuid())
  tenantId  String
  memberId  String
  bookingId String?

  checkInTime  DateTime  @default(now())
  checkOutTime DateTime?

  method CheckInMethod
  status AttendanceStatus @default(PRESENT)
  type   AttendanceType

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member  MemberProfile     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  booking Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  events  AttendanceEvent[]

  @@unique([bookingId, memberId])
  @@index([tenantId, checkInTime])
}

model AttendanceEvent {
  id           String   @id @default(cuid())
  attendanceId String?
  tenantId     String
  memberId     String
  eventType    String // e.g., "CHECK_IN_SUCCESS", "MEMBERSHIP_OVERRIDE", "DENIED_EXPIRED"
  overrideType String? // e.g., "EMERGENCY_ACCESS", "PROMOTIONAL_ACCESS", "STAFF_TESTING"
  timestamp    DateTime @default(now())
  notes        String?

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
}

model ProgressRecord {
  id         String        @id @default(cuid())
  memberId   String
  member     MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId   String
  recordedBy String
  weightKg   Float?
  bodyFatPct Float?
  muscleMass Float?
  chestCm    Float?
  waistCm    Float?
  hipsCm     Float?
  notes      String?
  recordedAt DateTime      @default(now())

  @@index([memberId, recordedAt])
  @@index([tenantId, recordedAt])
}

model MealPlan {
  id            String        @id @default(cuid())
  memberId      String
  member        MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId      String
  title         String
  goal          DietGoal      @default(GENERAL_HEALTH)
  totalCalories Int
  protein       Float
  carbs         Float
  fats          Float
  meals         Json
  isAiGenerated Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([memberId])
  @@index([tenantId, createdAt])
}

model FoodLog {
  id        String        @id @default(cuid())
  memberId  String
  member    MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // ✅ Phase 2: tenant isolation — non-nullable after Migration B backfill
  tenantId  String
  date      DateTime      @default(now())
  mealType  String
  foodName  String
  calories  Int
  protein   Float
  carbs     Float
  fats      Float
  quantity  Float         @default(1)
  unit      String        @default("serving")
  createdAt DateTime      @default(now())

  @@index([memberId, date])
  @@index([tenantId, date])
}

model Post {
  id        String     @id @default(cuid())
  tenantId  String
  authorId  String
  author    User       @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  imageUrl  String?
  likes     PostLike[]
  comments  Comment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([tenantId, createdAt])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model Challenge {
  id          String           @id @default(cuid())
  tenantId    String
  title       String
  description String
  type        ChallengeType    @default(CUSTOM)
  goal        Int
  unit        String
  startDate   DateTime
  endDate     DateTime
  createdBy   String
  entries     ChallengeEntry[]
  createdAt   DateTime         @default(now())

  @@index([tenantId])
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("UserChallenges", fields: [userId], references: [id], onDelete: Cascade)
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  joinedAt    DateTime  @default(now())

  @@unique([challengeId, userId])
  @@index([challengeId, progress])
}

model Badge {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserBadges", fields: [userId], references: [id], onDelete: Cascade)
  type      BadgeType
  awardedAt DateTime  @default(now())

  @@unique([userId, type])
  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([tenantId, read])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2: New Models
// ─────────────────────────────────────────────────────────────────────────────

model TenantSettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultCurrency Currency @default(NGN)

  // ── Branding ──────────────────────────────────────────────────────────────
  logoUrl           String?
  faviconUrl        String?
  primaryColor      String? // e.g. "#6366F1"
  secondaryColor    String?
  accentColor       String?
  fontFamily        String? // e.g. "Inter"
  darkMode          Boolean @default(false)
  brandName         String?
  whiteLabelEnabled Boolean @default(false)

  // ── Domain ────────────────────────────────────────────────────────────────
  customDomain      String?   @unique
  subdomain         String?   @unique
  domainVerified    Boolean   @default(false)
  verificationToken String? // Stores Vercel TXT challenge
  dnsVerifiedAt     DateTime? // Audit trail for verification

  // ── SaaS Billing (Phase 12 Paystack) ────────────────────────────────────────
  subscriptionPlan         String    @default("FREE")
  subscriptionStatus       String    @default("inactive")
  currentPeriodEnd         DateTime?
  paystackCustomerCode     String?   @unique
  paystackSubscriptionCode String?   @unique
  paystackEmailToken       String?

  // ── Business Info ─────────────────────────────────────────────────────────
  tagline     String?
  description String? @db.Text
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  country     String? @default("Nigeria")
  mapEmbedUrl String?

  // ── Social Links ──────────────────────────────────────────────────────────
  instagramUrl   String?
  facebookUrl    String?
  twitterUrl     String?
  tiktokUrl      String?
  whatsappNumber String?
  youtubeUrl     String?

  // ── Marketing CMS (JSON blobs, one per section) ───────────────────────────
  heroData        Json? // { headline, subheadline, ctaText, ctaUrl, bgImageUrl, overlayOpacity }
  aboutData       Json? // { story, mission, vision, teamImageUrl, foundedYear, highlights[] }
  servicesData    Json? // [{ icon, title, description, imageUrl }]
  galleryData     Json? // [{ imageUrl, caption, category }]
  testimonialData Json? // [{ name, role, quote, avatarUrl, rating }]
  contactData     Json? // { formEnabled, successMessage }
  featuresData    Json? // [{ icon, title, description }]
  statsData       Json? // [{ value, label }]
  openingHours    Json? // { monday: { open, close }, tuesday: ... }
  homepageLayout  Json? // Array of section IDs e.g. ["hero", "stats", "gallery", ...]

  // ── SEO ───────────────────────────────────────────────────────────────────
  metaTitle         String?
  metaDescription   String?
  ogImageUrl        String?
  googleAnalyticsId String?

  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId    String
  title       String
  slug        String
  excerpt     String?
  content     String    @db.Text
  coverImage  String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, published, publishedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 8: AI Usage Logging
// ─────────────────────────────────────────────────────────────────────────────

enum AiFeature {
  CHAT
  WORKOUT
  NUTRITION
  PROGRESS
}

model AiLog {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  feature      AiFeature
  model        String    @default("gemini-2.0-flash")
  // Approximate token counts (filled in when available from API response)
  inputTokens  Int?
  outputTokens Int?
  // Whether the call succeeded or was rejected (e.g. parse failure)
  success      Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, feature])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 19: INTELLIGENCE FEEDBACK LOOP
// ─────────────────────────────────────────────────────────────────────────────

model ActionRegistry {
  id         String    @id @default(cuid())
  tenantId   String
  actionType String // WIN_BACK_OFFER, PRICE_INCREASE, etc.
  targetId   String // memberId, trainerId, etc.
  context    String
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED, EXECUTED, EXPIRED
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  executedAt DateTime?

  feedback ActionFeedback?
}

model ActionFeedback {
  id           String         @id @default(cuid())
  actionId     String         @unique
  action       ActionRegistry @relation(fields: [actionId], references: [id], onDelete: Cascade)
  beforeMetric Float
  afterMetric  Float?
  delta        Float?
  success      Boolean        @default(false)
  measuredAt   DateTime?
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 17 SCAFFOLDING (ANALYTICS & RETENTION)Monetization
// ─────────────────────────────────────────────────────────────────────────────

model SaaSInvoice {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  amount    Decimal  @db.Decimal(10, 2)
  status    String   @default("pending") // pending, paid, failed
  reference String   @unique
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ── Webhook Idempotency & Audit (Phase 12) ──────────────────────────────────
model BillingEvent {
  id        String   @id @default(cuid())
  tenantId  String
  eventId   String   @unique
  eventType String
  payload   Json
  createdAt DateTime @default(now())
}

// ── Phase 15 Payments & Revenue ──────────────────────────────────────────────
model Transaction {
  id       String @id @default(cuid())
  tenantId String
  memberId String

  // IMMUTABLE SNAPSHOT DATA
  itemName String
  itemType PaymentType
  amount   Decimal     @db.Decimal(10, 2)
  currency Currency

  status    PaymentStatus @default(PENDING)
  reference String        @unique // Paystack Reference
  metadata  Json?

  // REFUND ARCHITECTURE
  refundedAmount Decimal?  @db.Decimal(10, 2)
  refundReason   String?
  refundedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  member  MemberProfile @relation(fields: [memberId], references: [id])
  receipt Receipt?

  @@index([tenantId, createdAt])
  @@index([memberId])
}

model PaymentEvent {
  id          String    @id @default(cuid())
  eventKey    String    @unique
  reference   String?
  eventType   String
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())
}

model EntitlementLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  planId    String?
  feature   String // e.g. "MAX_CLASSES_PER_MONTH", "AI_ACCESS"
  allowed   Boolean // true = allowed, false = blocked
  reason    String? // e.g. "Limit reached (4)"
  quantity  Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   MembershipPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([tenantId, planId])
  @@index([tenantId, feature, allowed])
  @@index([createdAt])
}

// ── Phase 17 Receipts ────────────────────────────────────────────────────────

model ReceiptSequence {
  id        String @id @default(cuid())
  tenantId  String
  yearMonth String // format: "YYYYMM"
  lastValue Int    @default(0)

  @@unique([tenantId, yearMonth])
}

model Receipt {
  id            String    @id @default(cuid())
  transactionId String    @unique
  receiptNumber String    @unique
  tenantId      String
  memberId      String
  sentAt        DateTime?
  status        String    @default("PENDING") // PENDING, SENT, FAILED
  metadata      Json?

  transaction Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  member      MemberProfile @relation(fields: [memberId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

enum AdminNotificationType {
  NEW_TENANT_SIGNUP
}

enum AdminNotificationStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

model AdminNotificationLog {
  id             String                  @id @default(cuid())
  idempotencyKey String                  @unique
  type           AdminNotificationType
  status         AdminNotificationStatus @default(QUEUED)
  recipients     String
  payload        Json
  error          String?
  tenantId       String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([status])
  @@index([tenantId])
}
